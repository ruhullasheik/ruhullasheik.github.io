#!/bin/sh
# Regenerate resume PDF if the markdown source changed

if git diff --cached --name-only | grep -q "sources/Ruhulla_Sheik_Resume.md"; then
    echo "Resume MD changed — regenerating PDF..."
    uv run python scripts/generate_resume.py
    git add downloads/Ruhulla_Sheik_Resume.pdf
    echo "PDF updated and staged."
fi
